  worksite      Worksite                        @relation(fields: [worksiteId], references: [id], onDelete: Cascade)
  verifications SsmPsiEquipmentVerification[]

  @@unique([tenantId, code])
  @@index([tenantId, worksiteId, status])
  @@index([tenantId, nextDueAt])
}

model SsmPsiEquipmentVerification {
