generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SystemRole {
  SSM_ADMIN
  SSM_ENTITY_RESPONSIBLE
  DEPARTMENT_MANAGER
  ITM_INSPECTOR
  EMPLOYEE
}

enum SsmResponsibleType {
  DESIGNATED_WORKER
  EXTERNAL_SERVICE
}

enum SsmDocumentType {
  IPSSM
  RISK_ASSESSMENT
  PPP
  THEMATIC
  DECISION
  PSI
  REGISTER
  OTHER
}

enum SsmDocumentStatus {
  ACTIVE
  ARCHIVED
}

enum SsmDocumentTargetType {
  JOB_POSITION
  DEPARTMENT
  WORKSITE
  ENTITY
  ALL
}

enum SsmTrainingPlanStatus {
  PENDING
  COMPLETED
  OVERDUE
  BLOCKED
}

enum SsmTrainingCategory {
  INTRODUCTORY_GENERAL
  WORKPLACE
  PERIODIC
  SUPPLEMENTARY
  EMERGENCY_PSI
}

enum SsmEipMovementType {
  DISTRIBUTION
  RETURN
  SCRAP
}

enum SsmAccidentType {
  ACCIDENT
  INCIDENT
  OCCUPATIONAL_DISEASE
}

enum SsmAccidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum SsmAccidentCaseStatus {
  OPEN
  IN_RESEARCH
  MEASURES_DEFINED
  CLOSED
}

enum SsmMedicalControlResult {
  FIT
  FIT_CONDITIONAL
  TEMPORARY_UNFIT
  UNFIT
}

enum SsmRiskAssessmentStatus {
  ACTIVE
  ARCHIVED
}

enum SsmRiskTargetType {
  JOB_POSITION
  WORKSITE
  DEPARTMENT
}

enum SsmPsiEquipmentStatus {
  ACTIVE
  RETIRED
}

enum SsmPsiResponsibleRole {
  PSI_RESPONSIBLE
  EMERGENCY_COORDINATOR
  EVACUATION_RESPONSIBLE
  FIRST_AID_RESPONSIBLE
}

enum CommunicationContentType {
  TEXT
  RICH_TEXT
  LINK
  DOCUMENT
  SURVEY
}

enum CommunicationCategory {
  GENERAL
  SAFETY_ALERT
  POLICY
  TRAINING_INFO
  SSM_COMPLIANCE
  HR_INFO
}

enum CommunicationAudienceType {
  ALL
  WORKSITE
  DEPARTMENT
  JOB_POSITION
  EMPLOYEE_GROUP
  EMPLOYEE
  CUSTOM
}

enum CommunicationAnnouncementStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  RETRACTED
  ARCHIVED
}

enum SurveyStatus {
  DRAFT
  ACTIVE
  CLOSED
  ARCHIVED
}

enum SurveyQuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  SCALE
  TEXT
  LONG_TEXT
  DATE
  BOOLEAN
  NUMBER
  RATING_NPS
}

enum SurveyType {
  ENGAGEMENT
  COMPLIANCE
  FEEDBACK
  EXIT
  PULSE
  CUSTOM
}

enum SurveyAudienceType {
  ALL
  WORKSITE
  DEPARTMENT
  JOB_POSITION
  EMPLOYEE_GROUP
  EMPLOYEE
  CUSTOM
}

enum HelpdeskTicketStatus {
  OPEN
  WAITING_OPERATOR
  WAITING_USER
  WAITING_INFO
  CLOSED
}

enum HelpdeskTicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum HelpdeskTicketSource {
  PORTAL
  SURVEY
  CHATBOT
  EMAIL
  MANUAL
}

enum RoleAssignmentScope {
  WORKSITE
  EMPLOYEE_GROUP
}

enum EmployeeStaticAudienceType {
  ALL
  WORKSITE
  EMPLOYEE_GROUP
}

model Tenant {
  id        String   @id
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  employees                  Employee[]
  ssmTrainingAssignments     SsmTrainingAssignment[]
  auditLogs                  AuditLog[]
  users                      User[]
  worksites                  Worksite[]
  departments                Department[]
  jobPositions               JobPosition[]
  employeePlacementHistories EmployeePlacementHistory[]
  employeeGroups             EmployeeGroup[]
  ssmResponsibles            SsmResponsible[]
  ssmDocuments               SsmDocument[]
  ssmDocumentVersions        SsmDocumentVersion[]
  ssmTrainingTypes           SsmTrainingType[]
  ssmTrainingPlans           SsmTrainingPlan[]
  ssmTrainingTestAttempts    SsmTrainingTestAttempt[]
  ssmTrainingSignatures      SsmTrainingSignature[]
  ssmTrainingReminderDispatches SsmTrainingReminderDispatch[]
  ssmEipTypes                SsmEipType[]
  ssmEipNorms                SsmEipNorm[]
  ssmEipStocks               SsmEipStock[]
  ssmEipMovements            SsmEipMovement[]
  ssmAccidentCases           SsmAccidentCase[]
  ssmAccidentTasks           SsmAccidentTask[]
  ssmMedicalControlTypes     SsmMedicalControlType[]
  ssmMedicalControls         SsmMedicalControl[]
  ssmRiskAssessments         SsmRiskAssessment[]
  ssmRiskAssessmentVersions  SsmRiskAssessmentVersion[]
  ssmPsiEquipments           SsmPsiEquipment[]
  ssmPsiEquipmentVerifications SsmPsiEquipmentVerification[]
  ssmPsiTrainingRecords      SsmPsiTrainingRecord[]
  ssmPsiResponsibles         SsmPsiResponsible[]
  ssmDocumentTemplates       SsmDocumentTemplate[]
  communicationAnnouncements CommunicationAnnouncement[]
  communicationTemplates      CommunicationTemplate[]
  communicationAnnouncementReads CommunicationAnnouncementRead[]
  communicationReminderDispatches CommunicationReminderDispatch[]
  surveys                    Survey[]
  surveyResponses            SurveyResponse[]
  helpdeskTickets            HelpdeskTicket[]
  helpdeskTicketComments     HelpdeskTicketComment[]
  userScopedRoles            UserScopedRole[]
  employeeStaticPages        EmployeeStaticPage[]
  inAppNotifications         InAppNotification[]
}

model User {
  id           String       @id @default(cuid())
  tenantId     String
  email        String
  passwordHash String
  fullName     String?
  active       Boolean      @default(true)
  roles        SystemRole[] @default([])
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  tenant           Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  scopedRoles      UserScopedRole[]
  inAppNotifications InAppNotification[]

  @@unique([tenantId, email])
  @@index([tenantId, active])
}

model Worksite {
  id        String   @id @default(cuid())
  tenantId  String
  code      String
  name      String
  address   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant                     Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  departments                Department[]
  employees                  Employee[]
  employeePlacementHistories EmployeePlacementHistory[]
  ssmResponsibles            SsmResponsible[]
  ssmRiskAssessments         SsmRiskAssessment[]
  ssmPsiEquipments           SsmPsiEquipment[]
  ssmPsiTrainingRecords      SsmPsiTrainingRecord[]
  ssmPsiResponsibles         SsmPsiResponsible[]
  userScopedRoles            UserScopedRole[]

  @@unique([tenantId, code])
  @@index([tenantId, active])
}

model Department {
  id         String   @id @default(cuid())
  tenantId   String
  worksiteId String?
  code       String
  name       String
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant                     Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  worksite                   Worksite?                  @relation(fields: [worksiteId], references: [id], onDelete: SetNull)
  jobPositions               JobPosition[]
  employees                  Employee[]
  employeePlacementHistories EmployeePlacementHistory[]
  ssmRiskAssessments         SsmRiskAssessment[]

  @@unique([tenantId, code])
  @@index([tenantId, worksiteId])
}

model JobPosition {
  id           String   @id @default(cuid())
  tenantId     String
  departmentId String?
  code         String
  name         String
  corCode      String?
  description  String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant                     Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department                 Department?                @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  employees                  Employee[]
  employeePlacementHistories EmployeePlacementHistory[]
  ssmEipNorms                SsmEipNorm[]
  ssmMedicalControlTypes     SsmMedicalControlType[]
  ssmRiskAssessments         SsmRiskAssessment[]

  @@unique([tenantId, code])
  @@index([tenantId, departmentId])
}

model Employee {
  id            String    @id @default(cuid())
  tenantId      String
  fullName      String
  email         String
  cnp           String?
  active        Boolean   @default(true)
  hireDate      DateTime?
  leaveDate     DateTime?
  worksiteId    String?
  departmentId  String?
  jobPositionId String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant                 Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  worksite               Worksite?                  @relation(fields: [worksiteId], references: [id], onDelete: SetNull)
  department             Department?                @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  jobPosition            JobPosition?               @relation(fields: [jobPositionId], references: [id], onDelete: SetNull)
  placementHistory       EmployeePlacementHistory[]
  groupMembers           EmployeeGroupMember[]
  ssmTrainingAssignments SsmTrainingAssignment[]
  ssmTrainingPlans       SsmTrainingPlan[]
  ssmEipMovements        SsmEipMovement[]
  ssmAccidentCases       SsmAccidentCase[]
  ssmMedicalControls     SsmMedicalControl[]
  ssmPsiTrainingRecords  SsmPsiTrainingRecord[]
  ssmPsiResponsibles     SsmPsiResponsible[]
  communicationAnnouncementReads CommunicationAnnouncementRead[]
  surveyResponses        SurveyResponse[]
  helpdeskTickets        HelpdeskTicket[]

  @@unique([tenantId, email])
  @@index([tenantId, active])
  @@index([tenantId, worksiteId])
  @@index([tenantId, departmentId])
}

model EmployeePlacementHistory {
  id              String    @id @default(cuid())
  tenantId        String
  employeeId      String
  effectiveFrom   DateTime  @default(now())
  effectiveTo     DateTime?
  worksiteId      String?
  departmentId    String?
  jobPositionId   String?
  changeReason    String?
  createdAt       DateTime  @default(now())
  createdByUserId String

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee    Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  worksite    Worksite?    @relation(fields: [worksiteId], references: [id], onDelete: SetNull)
  department  Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  jobPosition JobPosition? @relation(fields: [jobPositionId], references: [id], onDelete: SetNull)

  @@index([tenantId, employeeId])
  @@index([tenantId, effectiveFrom])
}

model EmployeeGroup {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant          Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  members         EmployeeGroupMember[]
  userScopedRoles UserScopedRole[]

  @@unique([tenantId, name])
  @@index([tenantId, active])
}

model EmployeeGroupMember {
  groupId    String
  employeeId String
  addedAt    DateTime @default(now())

  group    EmployeeGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  employee Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@id([groupId, employeeId])
}

model SsmResponsible {
  id         String             @id @default(cuid())
  tenantId   String
  worksiteId String?
  type       SsmResponsibleType
  personName String
  email      String?
  phone      String?
  notes      String?
  active     Boolean            @default(true)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  worksite Worksite? @relation(fields: [worksiteId], references: [id], onDelete: SetNull)

  @@index([tenantId, worksiteId])
  @@index([tenantId, active])
}

model SsmTrainingAssignment {
  id           String   @id @default(cuid())
  tenantId     String
  employeeId   String
  trainingCode String
  dueDate      DateTime
  completedAt  DateTime?
  assignedBy   String
  createdAt    DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([tenantId, employeeId])
  @@index([tenantId, trainingCode])
}

model SsmDocument {
  id              String                @id @default(cuid())
  tenantId        String
  title           String
  type            SsmDocumentType
  entityName      String?
  departmentName  String?
  jobPositionName String?
  periodStart     DateTime?
  periodEnd       DateTime?
  targetType      SsmDocumentTargetType
  targetRefId     String?
  targetLabel     String?
  status          SsmDocumentStatus     @default(ACTIVE)
  isControlFolder Boolean               @default(false)
  activeVersionId String?
  createdBy       String
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  tenant        Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  versions      SsmDocumentVersion[] @relation("DocumentVersions")
  activeVersion SsmDocumentVersion?  @relation("ActiveDocumentVersion", fields: [activeVersionId], references: [id], onDelete: SetNull)

  @@index([tenantId, type, status])
  @@index([tenantId, targetType, status])
  @@index([tenantId, isControlFolder, status])
}

model SsmDocumentVersion {
  id            String   @id @default(cuid())
  tenantId      String
  documentId    String
  versionNumber Int
  fileName      String
  mimeType      String
  fileSize      Int
  storagePath   String
  changeNote           String?
  retentionArchivedAt  DateTime?
  createdBy            String
  createdAt            DateTime @default(now())

  tenant             Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  document           SsmDocument   @relation("DocumentVersions", fields: [documentId], references: [id], onDelete: Cascade)
  activeForDocuments SsmDocument[] @relation("ActiveDocumentVersion")

  @@unique([documentId, versionNumber])
  @@index([tenantId, documentId, createdAt])
  @@index([tenantId, retentionArchivedAt])
}

model SsmTrainingType {
  id             String   @id @default(cuid())
  tenantId       String
  code           String
  name           String
  category       SsmTrainingCategory @default(PERIODIC)
  legalMinDurationHours Int?
  description    String?
  recurrenceDays Int?
  reminderDays   Int[]    @default([30, 15, 7])
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plans  SsmTrainingPlan[]

  @@unique([tenantId, code])
  @@index([tenantId, active])
}

model SsmTrainingReminderDispatch {
  id             String   @id @default(cuid())
  tenantId       String
  trainingPlanId String
  daysUntilDue   Int
  channel        String
  sentAt         DateTime @default(now())

  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  trainingPlan SsmTrainingPlan @relation(fields: [trainingPlanId], references: [id], onDelete: Cascade)

  @@unique([trainingPlanId, daysUntilDue, channel])
  @@index([tenantId, sentAt])
}

model SsmTrainingPlan {
  id                  String                @id @default(cuid())
  tenantId            String
  employeeId          String
  trainingTypeId      String
  materialTitle       String?
  materialUrl         String?
  materialCompletedAt DateTime?
  scheduledAt         DateTime
  dueAt               DateTime
  completedAt         DateTime?
  score               Float?
  durationMinutes     Int?
  status              SsmTrainingPlanStatus @default(PENDING)
  blockedAdmission    Boolean               @default(false)
  createdBy           String
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  tenant       Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee     Employee                @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  trainingType SsmTrainingType         @relation(fields: [trainingTypeId], references: [id], onDelete: Cascade)
  attempts     SsmTrainingTestAttempt[]
  signature    SsmTrainingSignature?
  reminderDispatches SsmTrainingReminderDispatch[]

  @@index([tenantId, employeeId, status])
  @@index([tenantId, dueAt, status])
  @@index([tenantId, blockedAdmission])
}

model SsmTrainingTestAttempt {
  id              String   @id @default(cuid())
  tenantId        String
  trainingPlanId  String
  startedAt       DateTime @default(now())
  finishedAt      DateTime?
  score           Float?
  durationSeconds Int?
  passed          Boolean?
  answersJson     Json?
  createdAt       DateTime @default(now())

  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  trainingPlan SsmTrainingPlan @relation(fields: [trainingPlanId], references: [id], onDelete: Cascade)

  @@index([tenantId, trainingPlanId, startedAt])
}

model SsmTrainingSignature {
  id                     String   @id @default(cuid())
  tenantId               String
  trainingPlanId         String   @unique
  employeeSignature      String?
  responsibleSignature   String?
  employeeSignedAt       DateTime?
  responsibleSignedAt    DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  trainingPlan SsmTrainingPlan @relation(fields: [trainingPlanId], references: [id], onDelete: Cascade)

  @@index([tenantId, trainingPlanId])
}

model SsmEipType {
  id                 String    @id @default(cuid())
  tenantId           String
  code               String
  name               String
  defaultLifetimeDays Int?
  active             Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  norms  SsmEipNorm[]
  stocks SsmEipStock[]
  moves  SsmEipMovement[]

  @@unique([tenantId, code])
  @@index([tenantId, active])
}

model SsmEipNorm {
  id                String   @id @default(cuid())
  tenantId          String
  jobPositionId     String
  eipTypeId         String
  requiredQuantity  Int
  lifetimeDays      Int
  replacementRule   String?
  createdBy         String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  jobPosition JobPosition @relation(fields: [jobPositionId], references: [id], onDelete: Cascade)
  eipType     SsmEipType  @relation(fields: [eipTypeId], references: [id], onDelete: Cascade)

  @@unique([jobPositionId, eipTypeId])
  @@index([tenantId, jobPositionId])
}

model SsmEipStock {
  id               String   @id @default(cuid())
  tenantId         String
  eipTypeId        String
  quantityOnHand   Int      @default(0)
  minimumThreshold Int      @default(0)
  updatedAt        DateTime @updatedAt

  tenant  Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  eipType SsmEipType @relation(fields: [eipTypeId], references: [id], onDelete: Cascade)

  @@unique([tenantId, eipTypeId])
  @@index([tenantId, quantityOnHand])
}

model SsmEipMovement {
  id                String             @id @default(cuid())
  tenantId          String
  employeeId        String
  eipTypeId         String
  movementType      SsmEipMovementType
  quantity          Int
  movementDate      DateTime           @default(now())
  replacementDueAt  DateTime?
  signatureData     String?
  signedAt          DateTime?
  notes             String?
  createdBy         String
  createdAt         DateTime           @default(now())

  tenant   Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  eipType  SsmEipType @relation(fields: [eipTypeId], references: [id], onDelete: Cascade)

  @@index([tenantId, employeeId, movementDate])
  @@index([tenantId, replacementDueAt])
  @@index([tenantId, movementType])
}

model SsmAccidentCase {
  id                 String                @id @default(cuid())
  tenantId           String
  employeeId         String?
  type               SsmAccidentType
  severity           SsmAccidentSeverity
  status             SsmAccidentCaseStatus @default(OPEN)
  title              String
  occurredAt         DateTime
  location           String?
  description              String
  witnesses                String[]              @default([])
  itmDaysOff               Int?
  hasPermanentDisability   Boolean               @default(false)
  isFatality               Boolean               @default(false)
  conclusions              String?
  correctiveMeasures       String?
  legalDaysDeadline        Int                   @default(30)
  dueAt                    DateTime
  closedAt                 DateTime?
  createdBy                String
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt

  tenant   Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee?         @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  tasks    SsmAccidentTask[]

  @@index([tenantId, status, dueAt])
  @@index([tenantId, type, occurredAt])
}

model SsmAccidentTask {
  id             String   @id @default(cuid())
  tenantId       String
  accidentCaseId String
  title          String
  assignedTo     String?
  dueAt          DateTime
  completedAt    DateTime?
  notes          String?
  createdBy      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  accidentCase SsmAccidentCase @relation(fields: [accidentCaseId], references: [id], onDelete: Cascade)

  @@index([tenantId, dueAt, completedAt])
  @@index([tenantId, accidentCaseId])
}

model SsmMedicalControlType {
  id             String   @id @default(cuid())
  tenantId       String
  jobPositionId  String?
  code           String
  name           String
  recurrenceDays Int?
  reminderDays   Int[]    @default([30, 15, 7])
  active         Boolean  @default(true)
  createdBy      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  jobPosition JobPosition?   @relation(fields: [jobPositionId], references: [id], onDelete: SetNull)
  controls    SsmMedicalControl[]

  @@unique([tenantId, code])
  @@index([tenantId, active])
  @@index([tenantId, jobPositionId])
}

model SsmMedicalControl {
  id                   String                  @id @default(cuid())
  tenantId             String
  employeeId           String
  controlTypeId        String
  scheduledAt          DateTime
  performedAt          DateTime?
  result               SsmMedicalControlResult?
  recommendations      String?
  validityUntil        DateTime?
  nextDueAt            DateTime?
  aptitudeSheetPath    String?
  aptitudeSheetName    String?
  aptitudeSheetMime    String?
  aptitudeSheetSize    Int?
  createdBy            String
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt

  tenant      Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee    Employee              @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  controlType SsmMedicalControlType @relation(fields: [controlTypeId], references: [id], onDelete: Cascade)

  @@index([tenantId, employeeId, scheduledAt])
  @@index([tenantId, nextDueAt])
  @@index([tenantId, result])
}

model SsmRiskAssessment {
  id              String                  @id @default(cuid())
  tenantId        String
  title           String
  targetType      SsmRiskTargetType
  jobPositionId   String?
  worksiteId      String?
  departmentId    String?
  status          SsmRiskAssessmentStatus @default(ACTIVE)
  activeVersionId String?
  createdBy       String
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  tenant        Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  jobPosition   JobPosition?               @relation(fields: [jobPositionId], references: [id], onDelete: SetNull)
  worksite      Worksite?                  @relation(fields: [worksiteId], references: [id], onDelete: SetNull)
  department    Department?                @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  versions      SsmRiskAssessmentVersion[] @relation("RiskAssessmentVersions")
  activeVersion SsmRiskAssessmentVersion?  @relation("ActiveRiskAssessmentVersion", fields: [activeVersionId], references: [id], onDelete: SetNull)

  @@index([tenantId, targetType, status])
  @@index([tenantId, jobPositionId])
  @@index([tenantId, worksiteId])
  @@index([tenantId, departmentId])
}

model SsmRiskAssessmentVersion {
  id            String   @id @default(cuid())
  tenantId      String
  assessmentId  String
  versionNumber Int
  updateReason  String
  factors       Json
  measures      Json
  riskLevel     Int
  effectiveFrom DateTime?
  createdBy     String
  createdAt     DateTime @default(now())

  tenant               Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assessment           SsmRiskAssessment   @relation("RiskAssessmentVersions", fields: [assessmentId], references: [id], onDelete: Cascade)
  activeForAssessments SsmRiskAssessment[] @relation("ActiveRiskAssessmentVersion")

  @@unique([assessmentId, versionNumber])
  @@index([tenantId, assessmentId, createdAt])
  @@index([tenantId, riskLevel])
}

model SsmPsiEquipment {
