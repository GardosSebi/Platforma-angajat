model CommunicationAnnouncement {
  id                String                          @id @default(cuid())
  tenantId          String
  title             String
  body              String
  category          CommunicationCategory           @default(GENERAL)
  contentType       CommunicationContentType        @default(TEXT)
  contentUrl        String?
  audienceType      CommunicationAudienceType
  audienceRefId     String?
  audienceLabel     String?
  targetEmployeeIds String[]                        @default([])
  status            CommunicationAnnouncementStatus @default(DRAFT)
  publishAt         DateTime?
  expiresAt         DateTime?
  reminderAt        DateTime?
  lastReminderSentAt DateTime?
  templateId        String?
  duplicatedFromId  String?
  retractedAt       DateTime?
  createdBy         String
  createdAt         DateTime                        @default(now())
  updatedAt         DateTime                        @updatedAt

  tenant           Tenant                           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  template         CommunicationTemplate?           @relation(fields: [templateId], references: [id], onDelete: SetNull)
  readReceipts     CommunicationAnnouncementRead[]
  reminderDispatches CommunicationReminderDispatch[]

  @@index([tenantId, status, publishAt])
  @@index([tenantId, audienceType, audienceRefId])
  @@index([tenantId, createdAt])
}

model CommunicationAnnouncementRead {
  id             String   @id @default(cuid())
  tenantId       String
  announcementId String
  employeeId     String
  readAt         DateTime @default(now())

  tenant       Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  announcement CommunicationAnnouncement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  employee     Employee                  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([announcementId, employeeId])
  @@index([tenantId, announcementId, readAt])
  @@index([tenantId, employeeId, readAt])
}

model CommunicationTemplate {
  id             String                    @id @default(cuid())
  tenantId       String
  name           String
  title          String
  body           String
  category       CommunicationCategory     @default(GENERAL)
  contentType    CommunicationContentType  @default(TEXT)
  contentUrl     String?
  audienceType   CommunicationAudienceType @default(ALL)
  audienceRefId  String?
  audienceLabel  String?
  active         Boolean                   @default(true)
  createdBy      String
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  tenant        Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  announcements CommunicationAnnouncement[]

  @@unique([tenantId, name])
  @@index([tenantId, active])
}

model CommunicationReminderDispatch {
  id             String   @id @default(cuid())
  tenantId       String
  announcementId String
  scheduledFor   DateTime
  sentAt         DateTime @default(now())
  channel        String   @default("CHATBOT")
  createdBy      String

  tenant       Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  announcement CommunicationAnnouncement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@index([tenantId, scheduledFor, sentAt])
  @@index([tenantId, announcementId])
}

model Survey {
  id                  String             @id @default(cuid())
  tenantId            String
  title               String
  description         String?
  surveyType          SurveyType           @default(ENGAGEMENT)
  status              SurveyStatus       @default(DRAFT)
  closesAt            DateTime?
  audienceType        SurveyAudienceType @default(ALL)
  audienceRefId       String?
  audienceLabel       String?
  targetEmployeeIds   String[]           @default([])
  questionSchema      Json
  conditionalLogic    Json?
  privateLinkEnabled  Boolean            @default(true)
  publicToken         String?            @unique
  publicEnabled       Boolean            @default(false)
  publicExpiresAt     DateTime?
  publicResponseLimit Int?
  publicResponseCount Int                @default(0)
  createdBy           String
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  responses SurveyResponse[]

  @@index([tenantId, status, createdAt])
  @@index([tenantId, status, closesAt])
  @@index([tenantId, audienceType, audienceRefId])
}

model SsmDocumentTemplate {
