  employee Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  helpdeskTickets HelpdeskTicket[]

  @@unique([surveyId, respondentUserId])
  @@index([tenantId, surveyId, submittedAt])
  @@index([tenantId, employeeId, submittedAt])
  @@index([publicToken, submittedAt])
}

model HelpdeskTicket {
  id                     String                 @id @default(cuid())
  tenantId               String
  title                  String
  description            String
  category               String?
  status                 HelpdeskTicketStatus   @default(OPEN)
  priority               HelpdeskTicketPriority @default(MEDIUM)
  source                 HelpdeskTicketSource   @default(PORTAL)
  reporterEmployeeId     String?
  reporterName           String?
  reporterEmail          String?
  assignedToUserId       String?
  assignedToName         String?
  sourceSurveyResponseId String?
  dueAt                  DateTime?
  resolvedAt             DateTime?
  closedAt               DateTime?
  createdBy              String
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt

  tenant               Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reporterEmployee     Employee?              @relation(fields: [reporterEmployeeId], references: [id], onDelete: SetNull)
  sourceSurveyResponse SurveyResponse?        @relation(fields: [sourceSurveyResponseId], references: [id], onDelete: SetNull)
  comments             HelpdeskTicketComment[]

  @@index([tenantId, status, priority])
  @@index([tenantId, assignedToUserId, status])
  @@index([tenantId, reporterEmployeeId, createdAt])
  @@index([tenantId, source, createdAt])
}

